# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:4b
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_GENERATION_NUM_PREDICT=256


# Generation models
SMALL_GENERATION_MODEL=qwen3.5:0.8b
MEDIUM_GENERATION_MODEL=qwen3.5:2b
LARGE_GENERATION_MODEL=qwen3:4b
DEFAULT_GENERATION_MODEL=qwen3.5:2b

# Generation
ENABLE_GENERATION=true
GENERATION_TEMPERATURE=0.0
GENERATION_MAX_CONTEXT_SOURCES=5
GENERATION_MAX_CONTEXT_CHARS=6000
GENERATION_REQUIRE_CITATIONS=true
GENERATION_STRICT_GROUNDING=true
GENERATION_ENABLE_MODEL_FALLBACK=true
GENERATION_MAX_RETRIES=2

# Context assembly
CONTEXT_SNIPPET_MAX_CHARS=1200
CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_COMPRESSION_MODE=deterministic

# Answer validation
MIN_SOURCES_FOR_ANSWER=1
ALLOW_NO_SOURCE_ANSWER=false

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=telecom_all_sources_v1

# Knowledge base versioning
KB_VERSION=telecom_egypt_kb_v1
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:4b
INDEX_VERSION=telecom_all_sources_v1_qwen3_embedding_4b_ollama

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Paths
DATA_DIR=data
UPLOAD_DIR=data/uploads
INDEX_DIR=data/indexes
LOG_DIR=data/logs
KB_DIR=data/knowledge_base

# Retrieval defaults
DENSE_TOP_K=30
BM25_TOP_K=30
FINAL_TOP_K=5
RRF_K=60

# Pipeline routing defaults
ENABLE_RULE_BASED_ROUTING=true
ENABLE_LLM_ROUTING=false
ENABLE_MODEL_ROUTING=true
ENABLE_MODEL_FALLBACK=true

# Fast path: simple factual questions
FAST_DENSE_TOP_K=10
FAST_BM25_TOP_K=10
FAST_RERANK_TOP_K=10
FAST_FINAL_TOP_K=3

# Standard path: normal RAG questions
STANDARD_DENSE_TOP_K=30
STANDARD_BM25_TOP_K=30
STANDARD_RERANK_TOP_K=20
STANDARD_FINAL_TOP_K=5

# Deep path: complex comparison/upload/reasoning questions
DEEP_DENSE_TOP_K=50
DEEP_BM25_TOP_K=50
DEEP_RERANK_TOP_K=30
DEEP_FINAL_TOP_K=8

# Reranking
ENABLE_RERANKING=true
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANKER_FALLBACK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_TOP_K=30
RERANK_BATCH_SIZE=4
RERANK_MAX_LENGTH=1024
RERANK_DEVICE=auto
RERANK_STRICT_MODE=false
RERANK_LOAD_TIMEOUT_SECONDS=60

# Multi-query
ENABLE_MULTI_QUERY=true
MULTI_QUERY_MAX_VARIANTS=6

# Cost optimization
ENABLE_EXACT_CACHE=true
ENABLE_SEMANTIC_CACHE=true
SEMANTIC_CACHE_THRESHOLD=0.95
SEMANTIC_CACHE_COLLECTION=semantic_query_cache_v1
ENABLE_PROMPT_CACHE=true
ENABLE_EMBEDDING_CACHE=true
ENABLE_CONTEXT_COMPRESSION=true

# Monitoring
ENABLE_PROMETHEUS=true

# API
RAG_API_HOST=0.0.0.0
RAG_API_PORT=8000

# Streamlit
STREAMLIT_PORT=8501
